{
  "name": "flockctl",
  "version": "0.0.1-rc.1",
  "description": "AI task orchestration tool — local-first, single-user",
  "author": "Eduard Abdullin",
  "type": "module",
  "bin": {
    "flockctl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/bundled-skills dist/bundled-skills && npm run build:ui && rm -rf dist/ui && cp -r ui/dist dist/ui && rm -rf dist/__tests__",
    "build:ui": "cd ui && npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/server-entry.ts",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "status": "node dist/cli.js status",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "cd ui && tsc -b --noEmit",
    "lint:ui": "cd ui && npm run lint",
    "pretest": "npm run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && cd ui && tsc -b --noEmit",
    "test:smoke": "tsx tests/smoke/run.ts",
    "test:e2e": "cd ui && npx playwright test",
    "test:live": "tsx tests/live/run.ts",
    "check": "npm run typecheck && npm run typecheck:ui && cd ui && vite build --mode production > /dev/null && cd .. && vitest run && npm run test:smoke",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "migrations",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "agent",
    "orchestration",
    "local-first",
    "cli",
    "daemon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flockctl/flockctl.git"
  },
  "homepage": "https://github.com/Flockctl/flockctl#readme",
  "bugs": {
    "url": "https://github.com/Flockctl/flockctl/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "glob": "^13.0.6",
    "hono": "^4.12.12",
    "nanoid": "^5.1.7",
    "node-cron": "^4.2.1",
    "node-notifier": "^10.0.1",
    "openai": "^6.34.0",
    "simple-git": "^3.36.0",
    "which": "^6.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
